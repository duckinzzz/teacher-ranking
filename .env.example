# Django
SECRET_KEY=dev-secret-key-not-for-production
DEBUG=True
ALLOWED_HOSTS=*

# CORS (required for frontend dev server; leave empty in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF (required for production — your domain, e.g. https://example.com)
CSRF_TRUSTED_ORIGINS=

# Database
# Production: set DATABASE_URL (takes precedence over individual vars below)
# DATABASE_URL=postgres://user:password@host.docker.internal:5432/dbname
#
# Dev / fallback: individual vars (leave empty to use SQLite)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=teacher_ranking
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_HOST=db
# DB_PORT=5432

# Gunicorn
GUNICORN_WORKERS=3

# Optional
TIME_ZONE=UTC
# SECURE_SSL_REDIRECT=False  # keep False when behind a reverse proxy (Caddy/nginx) that terminates SSL
